    "login_menu_env_changed_restart": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Environment has changed. To avoid issues from switching back and forth, please restart the app."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "环境已经改变，为排除来回切环境可能导致的问题，请重启app"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "環境が変更されました。環境の切り替えによる問題を避けるため、アプリを再起動してください。"
          }
        }
      }
