    "assembly_portal_disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disclaimer"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "免责声明"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "免責事項"
          }
        }
      }
    },
    "assembly_portal_disclaimer_desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TRTC (this app) is a tryout app, whose copyright is owned by Tencent Cloud. This app is for tryout only and must not be used commercially. In accordance with relevant regulations, this app forbids pornographic, abusive, terrorism, and politically sensitive content. All audio/video interactions are recorded and archived."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "腾讯云音视频 TRTC（\"本产品\"）是由腾讯云提供的一款测试产品，腾讯云享有本产品的著作权和所有权。本产品仅用于功能体验，不得用于任何商业用途。 为配合相关部门监管要求，本产品音视频互动全程均有录音录像存档，严禁在使用中有任何色情、辱骂、暴恐、涉政等违规内容的传播。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tencent Cloud TRTC（本製品）はTencent Cloudが提供するテスト製品であり、Tencent Cloudが著作権と所有権を有します。本製品は機能体験のみを目的としており、商用利用は禁止です。 規制要件に基づき、本製品のすべてのオーディオ・ビデオインタラクションは録画・録音されます。わいせつ、暴言、暴力、テロなどの違法コンテンツの配信は固く禁じられています。"
          }
        }
      }
    },
    "assembly_portal_privacy": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Privacy"
