    "main_report_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Attention: This is a DEMO APP. Do not trust anyone asking you to transfer money. Report scam"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅用于业务功能体验，请勿轻信汇款、中奖等涉及钱款的信息，谨防上当受骗，立即举报"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "注意：これはデモアプリです。送金や当選に関する情報を信じないでください。通報してください"
          }
        }
      }
    },
    "main_trial_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "* The \"UI\" label indicates that the component comes with a ready-to-use UI kit."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "* UI 组件指该产品提供含 UI 快速集成方案，30 分钟上线同款能力"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "* UIコンポーネントとは、UIを含むクイック統合ソリューションを提供することを意味します"
          }
        }
      }
    },
