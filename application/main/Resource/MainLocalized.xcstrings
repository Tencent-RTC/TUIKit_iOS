    "main_safety_reminder_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Safety Reminder"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安全提示"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安全に関するご注意"
          }
        }
      }
    },
    "main_safety_reminder_first_para": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tencent Cloud Media Services App provides you with the demonstration and experience of Tencent Cloud Audio and Video and Communication Cloud Services. Please note:"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "腾讯云音视频 App 为您提供腾讯云音视频及通信云服务的演示与体验。请注意："
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tencent Cloudオーディオ・ビデオAppは、Tencent Cloudオーディオ・ビデオおよび通信クラウドサービスのデモと体験を提供します。ご注意ください："
          }
        }
      }
    },
    "main_safety_reminder_mid_para": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1. This App is for demonstration and experience purposes only, and should not be used for daily communication or business transactions. 2. Please do not disclose your personal information, account password, or other sensitive information to strangers to protect your privacy and security. 3. Be vigilant about remittance, winning a prize, and other money-related information to avoid being deceived. 4. If you encounter any suspicious situations, please report to us promptly, and we will verify and handle it as soon as possible."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 本App用途仅适用于演示和体验，请勿用于日常沟通或商业交易。 2. 请勿向陌生人透露您的个人信息、账号密码等敏感信息，以保护您的隐私安全。 3. 请务必警惕汇款、中奖等涉及钱款的信息，避免上当受骗。 4. 如遇到可疑情况，请及时向我们反馈，我们将尽快为您核实处理。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 本アプリはデモおよび体験のみを目的としており、日常の連絡や商取引にはご利用にならないでください。 2. プライバシー保護のため、見知らぬ人に個人情報やアカウントのパスワードなどを教えないでください。 3. 送金や当選に関する金銭情報にはご注意ください。 4. 不審な状況に遭遇した場合は、直ちにフィードバックをお寄せください。速やかに確認・対処いたします。"
          }
        }
      }
    },
    "main_safety_reminder_end_para": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thank you for your understanding and support, wish you a pleasant use!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "感谢您的理解与支持，祝您使用愉快！"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ご理解とご支援に感謝いたします。快適なご利用をお祈りしております！"
          }
        }
      }
    },
    "main_safety_reminder_confirm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GOT IT"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我知道了"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "了解しました"
          }
        }
      }
    },
    "main_module_banned_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your account is at risk and has been restricted."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的账户存在风险，已被限制使用"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントにリスクがあり、利用が制限されています。"
          }
        }
      }
    },
