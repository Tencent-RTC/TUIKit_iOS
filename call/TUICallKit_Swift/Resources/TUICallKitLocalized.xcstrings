{
  "sourceLanguage": "en",
  "strings": {
    "TUICallKit.inviteToVideoCall": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "invites you to a video call"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邀请你视频通话"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "邀請你視頻通話"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビデオ通話に招待されました"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يدعوك لمكالمة فيديو"
          }
        }
      }
    },
    "TUICallKit.inviteToAudioCall": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "invites you to a voice call"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邀请你语音通话"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "邀請你語音通話"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声通話に招待されました"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يدعوك لمكالمة صوتية"
          }
        }
      }
    },
    "TUICallKit.Group.inviteToGroupCall": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "invites you to a group call"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邀请你加入多人通话"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "邀請你加入多人通話"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "グループ通話に招待します"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يدعوك إلى مكالمة"
          }
        }
      }
    },
    "TUICallKit.determine": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Confirm"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تأكيد "
          }
        }
      }
    },
    "TUICallKit.lineBusy": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The other party is busy. Please try again later"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对方正在忙，请稍后再试"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對方正在通話中，請稍後再試"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "相手は通話中です。しばらくしてからもう一度お試しください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الطرف الآخر في مكالمة، يرجى المحاولة مرة أخرى لاحقًا"
          }
        }
      }
    },
    "TUICallKit.otherPartyHangup": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The other party hung up, call ended"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对方已挂断，通话结束"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對方已掛斷，通話結束"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "相手が切断、通話終了"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنهى الطرف الآخر المكالمة"
          }
        }
      }
    },
    "TUICallKit.otherPartyReject": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The other party declined your call request"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对方拒绝了您的通话请求"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對方拒絕了您的通話請求"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "相手があなたの通話リクエストを拒否しました"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الطرف الآخر رفض طلب المكالمة الخاص بك"
          }
        }
      }
    },
    "TUICallKit.otherPartyNoResponse": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The other party did not answer. Please try again later"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对方未接听，请稍后再试"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對方未接聽，請稍後再試"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "相手が応答しませんでした。しばらくしてからもう一度お試しください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يجب الطرف الآخر، يرجى المحاولة مرة أخرى لاحقًا"
          }
        }
      }
    },
    "TUICallKit.otherPartyCanceled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The other party cancelled the call"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对方已取消通话"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對方已取消通話"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "相手が通話をキャンセルしました"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ألغى الطرف الآخر المكالمة"
          }
        }
      }
    },
    "TUICallKit.calNotCallYourself": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You cannot call yourself"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不能呼叫自己"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不能呼叫自己"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分自身に通話を開始できません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على الاتصال بنفسك"
          }
        }
      }
    },
    "TUICallKit.youHaveMissedCalls": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are currently in a call. Please end it before making a new one"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您当前正在通话中，请结束通话后再拨打"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您當前正在通話中，請結束通話後再撥打"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通話中のため、別の通話を開始できません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت في مكالمة ولا يمكنك بدء مكالمة أخرى"
          }
        }
      }
    },
    "TUICallKit.Recents.noCall": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Calls"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无通话记录"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "暫無通話記錄"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通話履歴がありません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد مكالمات"
          }
        }
      }
    },
    "TUICallKit.Recents.noMissedCall": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Missed Calls"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无未接来电"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "暫無未接來電"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "不在着信がありません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد مكالمات فائتة"
          }
        }
      }
    },
    "TUICallKit.ErrorInvalidUserId": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "User does not exist. Please verify if the user is registered or if invalid characters were entered"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户不存在，请确认该用户是否已注册或是否输入非法字符"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用戶不存在，請確認該用戶是否已註冊或是否輸入非法字符"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ユーザーが存在しません。登録済みか、または不正な文字が入力されていないかご確認ください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المستخدم غير موجود. يرجى التحقق مما إذا كان المستخدم مسجلاً أو إذا تم إدخال أحرف غير صالحة"
          }
        }
      }
    },
    "TUICallKit.ErrorGroupHasActiveCall": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This group already has an active call"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该群组已有通话正在进行中"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該群組已有通話正在進行中"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このグループではすでに通話が進行中です"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذه المجموعة لديها بالفعل مكالمة نشطة"
          }
        }
      }
    },
    "TUICallKit.User.Exceed.Limit": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This call supports a maximum of 9 participants"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前通话最多支持 9 人同时在线"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前通話最多支持 9 人同時在線"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の通話は最大9人まで同時にオンラインをサポートします"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تدعم المكالمة الحالية ما يصل إلى 9 أشخاص متصلين في وقت واحد"
          }
        }
      }
    },
    "TUICallKit.UnableToRestartTheCall": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are currently in a call. Please end it before making a new one"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您当前正在通话中，请结束通话后再拨打"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您當前正在通話中，請結束通話後再撥打"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在通話中です。通話を終了してから再度発信してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت حاليًا في مكالمة ، يرجى إنهاء المكالمة قبل الاتصال مرة أخرى"
          }
        }
      }
    },
    "TUICallKit.purchased": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This feature requires audio-video call capability package support. To avoid affecting your usage, it is recommended to go to Tencent Cloud · Real-Time Communication Console to activate free trial or purchase official package"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此功能需要音视频通话能力套餐支持，为不影响您的使用，建议您前往腾讯云·实时音视频控制台，开通免费体验或选购正式套餐"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此功能需要音視頻通話能力套餐支持，為不影響您的使用，建議您前往騰訊雲·實時音視頻控制台，開通免費體驗或選購正式套餐"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この機能には音声・ビデオ通話機能パッケージのサポートが必要です。ご利用に影響を与えないよう、Tencent Cloud・リアルタイムコミュニケーションコンソールにアクセスして、無料体験を有効にするか、正式パッケージを購入することをお勧めします"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتطلب هذه الميزة دعم حزمة قدرات المكالمات الصوتية والمرئية. لتجنب التأثير على استخدامك ، يوصى بالانتقال إلى Tencent Cloud · وحدة تحكم الاتصالات في الوقت الفعلي لتفعيل التجربة المجانية أو شراء الحزمة الرسمية"
          }
        }
      }
    },
    "TUICallKit.support": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your current package type does not support this feature. To unlock more capabilities, it is recommended to go to Tencent Cloud · Real-Time Communication Console to upgrade your package"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您当前的套餐类型暂不支持此功能，为解锁更多能力，建议您前往腾讯云·实时音视频控制台升级套餐"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您當前的套餐類型暫不支持此功能，為解鎖更多能力，建議您前往騰訊雲·實時音視頻控制台升級套餐"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のパッケージタイプはこの機能をサポートしていません。より多くの機能をアンロックするには、Tencent Cloud・リアルタイムコミュニケーションコンソールにアクセスしてパッケージをアップグレードすることをお勧めします"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نوع الحزمة الحالي الخاص بك لا يدعم هذه الميزة. لفتح المزيد من القدرات ، يوصى بالانتقال إلى Tencent Cloud · وحدة تحكم الاتصالات في الوقت الفعلي لترقية حزمتك"
          }
        }
      }
    },
    "TUICallKit.ErrorInPeerBlacklist": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The identifier is in blacklist. Failed to send this message!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发起通话失败，用户在黑名单中，禁止发起！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "發起通話失敗，用戶在黑名單中，禁止發起！"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通話の開始に失敗しました。ユーザーがブラックリストに登録されているため、発信が禁止されています！"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المعرف في القائمة السوداء. فشل في إرسال هذه الرسالة!"
          }
        }
      }
    },
    "TUICallKit.ErrorInvalidLogin": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to initiate the call. Please check your login status and try again"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发起通话失败，请检查登录状态后重试"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "發起通話失敗，請檢查登錄狀態後重試"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通話の開始に失敗しました。ログイン状態を確認して再試行してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل بدء المكالمة، يرجى التحقق من حالة تسجيل الدخول والمحاولة مرة أخرى"
          }
        }
      }
    },
    "TUICallKit.ErrorParameterInvalid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Parameter error"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "参数错误"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "參數錯誤"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パラメータエラー"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خطأ المعلمة"
          }
        }
      }
    },
    "TUICallKit.ErrorRequestRepeated": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The current status is waiting/accept, please do not call it repeatedly"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前方法正在执行中，请勿重复调用"
          }
