    "TUICallKit.FailedToGetCameraPermission.Tips": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera permission not enabled, unable to start video call. Go to Settings > %@ to enable camera permission"
          }
