    "SmartCellular.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Current WiFi network is unstable, switch to cellular data to improve call quality.\\n(Data charges may apply, depending on your plan)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 WiFi 网络不稳定，切换至蜂窝数据改善通话质量。\\n(可能产生流量费用，具体取决于您的套餐)"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前 WiFi 網絡不穩定，切換至蜂窩數據改善通話質量。\\n(可能產生流量費用，具體取決於您的套餐)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のWiFiネットワークが不安定です。モバイルデータ通信に切り替えて通話品質を改善します。\\n(ご利用のプランによってはデータ通信料が発生する場合があります)"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شبكة WiFi الحالية غير مستقرة، قم بالتبديل إلى بيانات الجوال لتحسين جودة المكالمة.\\n(قد يتم تطبيق رسوم بيانات حسب خطتك)"
          }
        }
      }
    },
