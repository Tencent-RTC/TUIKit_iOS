    "roomkit_transfer_host_with_asr_warning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After transferring room ownership, you will become a general member. Real-time Subtitles and AI Meeting Minutes will stop and must be re-enabled by the new host."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "转交房主后，您将成为普通成员。实时字幕 / AI 会议纪要将停止，需由新房主重新开启"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームオーナーを譲渡すると一般メンバーになります。リアルタイム字幕 / AI 議事録は停止し、新しいオーナーが再度有効にする必要があります。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد نقل ملكية الغرفة، ستصبح عضواً عادياً. سيتم إيقاف الترجمة الفورية / محضر الاجتماع بالذكاء الاصطناعي ويجب على المالك الجديد إعادة تفعيلها."
          }
        }
      }
