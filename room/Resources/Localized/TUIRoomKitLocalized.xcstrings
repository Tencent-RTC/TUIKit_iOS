    "roomkit_stop_screen_share_confirm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After ending sharing, others will no longer be able to view your screen. Are you sure you want to end sharing?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "结束共享后，其他人将无法继续观看你的屏幕内容，确定要结束共享吗？"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "共有を終了すると、他のユーザーはあなたの画面を視聴できなくなります。共有を終了してもよろしいですか？"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد إنهاء المشاركة، لن يتمكن الآخرون من الاستمرار في مشاهدة شاشتك. هل أنت متأكد أنك تريد إنهاء المشاركة؟"
          }
        }
      }
    },
    "roomkit_another_is_sharing_the_screen": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Another user is sharing the screen."
          }
