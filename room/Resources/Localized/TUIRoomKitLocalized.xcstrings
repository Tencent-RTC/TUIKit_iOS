            "state": "translated",
            "value": "مطلوب إذن صاحب الغرفة أو المسؤول للعملية"
          }
        }
      }
    },
    "roomkit_err_n2310_signal_no_permission": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No permission for signaling request, e.g. canceling an invite not initiated by yourself"
          }
        },
        "zh-Hans": {
          "stringUnit": {
