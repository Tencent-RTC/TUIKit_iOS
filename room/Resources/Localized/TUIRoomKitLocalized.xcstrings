    "roomkit_err_100002_server_invalid_parameter": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The parameter is illegal. check whether the request is correct according to the error description"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请参数非法，请根据错误描述检查请求是否正确"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パラメータが不正です。エラーの説明に従ってリクエストを確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المعلمة غير قانونية. تحقق مما إذا كان الطلب صحيحاً وفقاً لوصف الخطأ"
          }
        }
      }
    },
    "roomkit_err_100003_room_id_already_exists": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The room id already exists. please select another room id"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房间ID 已被使用，请选择别的房间ID"
          }
