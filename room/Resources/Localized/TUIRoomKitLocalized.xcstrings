      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Room ID does not match, please check if you have checked out or changed rooms."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房间 ID 不匹配，请检查是否退房或者切换了房间"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームIDが一致しません。退出または切り替えを確認してください。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معرف الغرفة غير متطابق، يرجى التحقق مما إذا كنت قد غادرت أو غيرت الغرف."
          }
        }
      }
    },
    "roomkit_err_n1000_sdk_appid_not_found": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not found sdkappid, please confirm application info in trtc console"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到 SDKAppID，请在 腾讯云视立方 SDK 控制台 确认应用信息"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "SDKAppIDが見つかりません。TRTCコンソールでアプリ情報を確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم العثور على SDKAppID، يرجى تأكيد معلومات التطبيق في وحدة تحكم TRTC"
          }
        }
      }
    },
    "roomkit_err_n1001_invalid_parameter": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Passing illegal parameters when calling api, check if the parameters are legal"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调用 API 时，传入的参数不合法，检查入参是否合法"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIを呼び出す際のパラメータが不正です。パラメータを確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تمرير معلمات غير قانونية عند استدعاء API، تحقق من صحة المعلمات"
          }
        }
      }
    },
    "roomkit_err_n1002_not_logged_in": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not logged in, please call login api"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未登录,请调用 Login 接口"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログインしていません。ログインAPIを呼び出してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم تسجيل الدخول، يرجى استدعاء API تسجيل الدخول"
          }
        }
      }
    },
    "roomkit_err_n1003_permission_denied": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to obtain permission, unauthorized audio/video permission, please check if device permission is enabled"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "获取权限失败，当前未授权音/视频权限，请查看是否开启设备权限"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "権限の取得に失敗しました。デバイスの権限が有効か確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل الحصول على الإذن، تحقق من تفعيل أذونات الجهاز"
          }
        }
      }
    },
    "roomkit_err_n1004_package_required": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This feature requires an additional package. please activate the corresponding package as needed in the trtc console"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该功能需要开通额外的套餐，请在 腾讯云视立方 SDK 控制台 按需开通对应套餐"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この機能には追加パッケージが必要です。TRTCコンソールで必要なパッケージを有効にしてください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتطلب هذه الميزة باقة إضافية. يرجى تفعيل الباقة المناسبة في وحدة تحكم TRTC"
          }
        }
      }
    },
    "roomkit_err_n1005_invalid_license": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "License is invalid or expired, please check its validity period in the trtc console. please activate the corresponding package as needed in the trtc console."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "License无效或已过期，请在 腾讯云视立方 SDK控制台确认License有效期"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライセンスが無効または期限切れです。TRTCコンソールで有効期限を確認してください。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الترخيص غير صالح أو منتهي الصلاحية، يرجى التحقق من صلاحيته في وحدة تحكم TRTC."
          }
        }
      }
    },
    "roomkit_err_n1100_camera_open_failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System issue, failed to open camera. check if camera device is normal"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统问题，打开摄像头失败。检查摄像头设备是否正常"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムの問題でカメラを開けませんでした。カメラデバイスを確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مشكلة في النظام، فشل فتح الكاميرا. تحقق من جهاز الكاميرا"
          }
        }
      }
    },
    "roomkit_err_n1101_camera_no_permission": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera has no system authorization, check system authorization"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "摄像头没有系统授权, 检查系统授权"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラにシステム権限がありません。システム権限を確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الكاميرا ليس لديها إذن النظام، تحقق من إذن النظام"
          }
        }
      }
    },
    "roomkit_err_n1102_camera_occupied": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera is occupied, check if other process is using camera"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "摄像头被占用，检查是否有其他进程使用摄像头"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラが使用中です。他のプロセスがカメラを使用していないか確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الكاميرا مشغولة، تحقق مما إذا كانت عملية أخرى تستخدم الكاميرا"
          }
        }
      }
    },
    "roomkit_err_n1103_camera_not_found": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No camera device currently, please insert camera device to solve the problem"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前无摄像头设备，请插入摄像头设备解决该问题"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラデバイスがありません。カメラデバイスを接続してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد جهاز كاميرا حالياً، يرجى توصيل جهاز كاميرا"
          }
        }
      }
    },
    "roomkit_err_n1104_mic_open_failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System issue, failed to open mic. check if mic device is normal"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统问题，打开麦克风失败。检查麦克风设备是否正常"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムの問題でマイクを開けませんでした。マイクデバイスを確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مشكلة في النظام، فشل فتح الميكروفون. تحقق من جهاز الميكروفون"
          }
        }
      }
    },
    "roomkit_err_n1105_mic_no_permission": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mic has no system authorization, check system authorization"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "麦克风没有系统授权，检查系统授权"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクにシステム権限がありません。システム権限を確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الميكروفون ليس لديه إذن النظام، تحقق من إذن النظام"
          }
        }
      }
    },
    "roomkit_err_n1106_mic_occupied": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mic is occupied"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "麦克风被占用"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクが使用中です"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الميكروفون مشغول"
          }
        }
      }
    },
    "roomkit_err_n1107_mic_not_found": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No mic device currently"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前无麦克风设备"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクデバイスがありません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد جهاز ميكروفون حالياً"
          }
        }
      }
    },
    "roomkit_err_n1108_screen_share_get_source_failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to get screen sharing source (screen and window), check screen recording permissions"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "获取屏幕分享源（屏幕和窗口）失败，检查屏幕录制权限"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面共有ソースの取得に失敗しました。画面録画の権限を確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل الحصول على مصدر مشاركة الشاشة، تحقق من أذونات تسجيل الشاشة"
          }
        }
      }
    },
    "roomkit_err_n1109_screen_share_start_failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to enable screen sharing, check if someone is already screen sharing in the room"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启屏幕分享失败，检查房间内是否有人正在屏幕分享"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面共有の開始に失敗しました。他の人が画面共有中か確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل تفعيل مشاركة الشاشة، تحقق مما إذا كان شخص آخر يشارك الشاشة"
          }
        }
      }
    },
    "roomkit_err_n2101_not_in_room": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This feature can only be used after entering the room"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要进房后才可使用此功能"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この機能はルームに入室後のみ使用できます"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن استخدام هذه الميزة فقط بعد دخول الغرفة"
          }
        }
      }
    },
    "roomkit_err_n2102_owner_cannot_leave": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Room owner does not support leaving the room, room owner can only close the room"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房主不支持退房操作，房主只能解散房间"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オーナーは退出できません。ルームを閉じることのみ可能です"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صاحب الغرفة لا يدعم مغادرة الغرفة، يمكنه فقط إغلاق الغرفة"
          }
        }
      }
    },
    "roomkit_err_n2103_unsupported_in_room_type": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This operation is not supported in the current room type"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前房间类型下不支持该操作"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のルームタイプではこの操作はサポートされていません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذه العملية غير مدعومة في نوع الغرفة الحالي"
          }
        }
      }
    },
    "roomkit_err_n2105_invalid_room_id": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Illegal custom room id, must be printable ascii characters (0x20–0x7e), up to 48 bytes long"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建房间 ID 非法，自定义 ID 必须为可打印 ASCII 字符（0x20–0x7e），最长48个字节"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームIDが不正です。印刷可能なASCII文字（0x20-0x7e）で最大48バイトである必要があります"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معرف الغرفة المخصص غير قانوني، يجب أن يكون أحرف ASCII قابلة للطباعة، بحد أقصى 48 بايت"
          }
        }
      }
    },
    "roomkit_err_n2107_invalid_room_name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Illegal room name, maximum 30 bytes, must be utf-8 encoding if contains chinese characters"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房间名称非法，名称最长30字节，字符编码必须是 UTF-8 ，如果包含中文"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルーム名が不正です。最大30バイトで、UTF-8エンコーディングである必要があります"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسم الغرفة غير قانوني، بحد أقصى 30 بايت، يجب أن يكون بترميز UTF-8"
          }
        }
      }
    },
    "roomkit_err_n2108_user_already_in_other_room": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "User is already in another room, single roomengine instance only supports user entering one room, to enter different room, please leave the room or use new roomengine instance"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前用户已在别的房间内，单个 roomEngine 实例只支持用户进入一个房间，如果要进入不同的房间请先退房或者使用新的 roomEngine 实例"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ユーザーは既に別のルームにいます。別のルームに入るには、まず退出するか新しいインスタンスを使用してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المستخدم موجود بالفعل في غرفة أخرى، للدخول إلى غرفة مختلفة، يرجى مغادرة الغرفة أو استخدام مثيل جديد"
          }
        }
      }
    },
    "roomkit_err_n2200_user_not_exist": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "User is not exist"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户不存在"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ユーザーが存在しません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المستخدم غير موجود"
          }
        }
      }
    },
    "roomkit_err_n2300_need_owner_permission": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Room owner permission required for operation"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要房主权限才能操作"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作にはオーナー権限が必要です"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مطلوب إذن صاحب الغرفة للعملية"
          }
        }
      }
    },
    "roomkit_err_n2301_need_admin_permission": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Room owner or administrator permission required for operation"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
