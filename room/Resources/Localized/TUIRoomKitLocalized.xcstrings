        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームIDは既に使用されています。別のルームIDを選択してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معرف الغرفة موجود بالفعل. يرجى اختيار معرف آخر"
          }
        }
      }
    },
    "roomkit_err_100004_room_not_exist": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The room does not exist, or it once existed but has now been dissolved"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房间不存在，或者曾经存在过，但是目前已经被解散"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームが存在しないか、既に解散されています"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الغرفة غير موجودة، أو كانت موجودة ولكن تم حلها"
          }
        }
      }
    },
    "roomkit_err_100005_not_room_member": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not a room member"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "非房间成员"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームメンバーではありません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ليس عضواً في الغرفة"
          }
        }
      }
    },
    "roomkit_err_100006_operation_not_allowed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are currently unable to perform this operation (possibly due to lack of permission or scenario restrictions)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您当前无法执行此操作（可能是无权限，或受场景限制等原因）"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作を実行できません（権限がないか、シナリオ制限のため）"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكنك حالياً تنفيذ هذه العملية (ربما بسبب نقص الإذن أو قيود السيناريو)"
          }
        }
      }
    },
    "roomkit_err_100007_no_payment_info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No payment information, you need to purchase a package in the console"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无付费信息，需在控制台购买套餐包"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "支払い情報がありません。コンソールでパッケージを購入してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد معلومات دفع، تحتاج لشراء باقة في وحدة التحكم"
          }
        }
      }
    },
    "roomkit_err_100008_room_is_full": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The room is full"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房间成员已满"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームが満員です"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الغرفة ممتلئة"
          }
        }
      }
    },
    "roomkit_err_100009_room_tag_limit_exceeded": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tag quantity exceeds upper limit"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标签数量超上限"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タグ数が上限を超えています"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عدد العلامات يتجاوز الحد الأعلى"
          }
        }
      }
    },
    "roomkit_err_100010_room_id_reusable_by_owner": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The room id has been used, and the operator is the room owner, it can be used directly"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房间 ID 已被使用，并且操作者为房主，可以直接使用"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームIDは既に使用されており、操作者がオーナーの場合は直接使用できます"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم استخدام معرف الغرفة، والمشغل هو صاحب الغرفة، يمكن استخدامه مباشرة"
          }
        }
      }
    },
    "roomkit_err_100011_room_id_occupied_by_im": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The room id has been occupied by chat. you can use a different room id or dissolve the group first"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房间 ID 已被 IM 占用，可以换一个房间 ID 使用，或者先通过 IM 接口解散该群"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルームIDはIMに使用されています。別のルームIDを使用するか、グループを解散してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معرف الغرفة مشغول بواسطة الدردشة. يمكنك استخدام معرف مختلف أو حل المجموعة أولاً"
          }
        }
      }
    },
    "roomkit_err_100012_create_room_frequency_limit": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creating rooms exceeds the frequency limit, the same room id can only be created once within 1 second"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "频率超过限制，例如创建房间超过频率超限，同一房间 ID， 1秒内只能创建一次"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルーム作成の頻度制限を超えています。同じルームIDは1秒に1回のみ作成可能です"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تجاوز إنشاء الغرف حد التردد، يمكن إنشاء نفس معرف الغرفة مرة واحدة فقط في الثانية"
          }
        }
      }
    },
    "roomkit_err_100013_payment_limit_exceeded": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
