    "roomkit_privacy_screen_share_tip_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Security reminder"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安全提醒"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セキュリティリマインダー"
          }
        },
        "ar": {
