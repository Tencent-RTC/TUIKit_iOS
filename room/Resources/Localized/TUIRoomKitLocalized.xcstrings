    "roomkit_privacy_screen_share_tip_content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen sharing may leak private information such as SMS verification codes and passwords, causing property loss. Please be vigilant against various fraudulent activities."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "共享屏幕时可能会泄露短信验证码、密码等隐私信息，造成财产损失，请警惕各种诈骗行为。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面共有によりSMS認証コードやパスワードなどの個人情報が漏洩し、財産損失を引き起こす可能性があります。様々な詐欺行為にご注意ください。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد تؤدي مشاركة الشاشة إلى تسريب معلومات خاصة مثل رموز التحقق عبر الرسائل القصيرة وكلمات المرور، مما يتسبب في خسائر مالية. يرجى توخي الحذر ضد الأنشطة الاحتيالية المختلفة."
          }
        }
      }
    },
    "roomkit_privacy_screen_share_tip_continue": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue sharing"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "继续共享"
          }
        },
